# ============================================================
# AppLabX WordPress Base — Environment variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# MySQL root password (used for database administration).
# Required if using the bundled MySQL 8 container.
# Leave unset for auth_socket authentication (default on MySQL 8).
MYSQL_ROOT_PASSWORD=change-me-in-production

# WordPress database password.
# Must match MYSQL_USER password in the compose file.
WORDPRESS_DB_PASSWORD=change-me-in-production

# Table prefix (change for security hardening).
# Keep alphanumeric + underscore only. Default is wp_.
WORDPRESS_TABLE_PREFIX=wp_

# Enable WordPress debug mode.
# NEVER enable in production (1 = on, 0 = off).
WORDPRESS_DEBUG=0
