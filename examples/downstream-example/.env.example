# ============================================================
# Environment variables — downstream example
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# MySQL root password (used for database administration)
MYSQL_ROOT_PASSWORD=change-me-in-production

# WordPress database password (must match MYSQL_WORDPRESS_PASSWORD)
WORDPRESS_DB_PASSWORD=change-me-in-production

# Table prefix (change for security; default is wp_)
# Keep this short and simple (letters, numbers, underscore only)
WORDPRESS_TABLE_PREFIX=wp_

# Enable WordPress debug mode (1 = on, 0 = off)
# NEVER enable debug in production
WORDPRESS_DEBUG=0
